# ========== Обязательно (локально и на Render) ==========
# SQLite: путь относительно папки prisma/ (файл prisma/dev.db в .gitignore)
DATABASE_URL="file:./dev.db"

# Минимум ~32 символа; в продакшене задайте случайные строки (openssl rand -hex 32)
JWT_ACCESS_SECRET="min-32-characters-secret-for-access-token-min"
JWT_REFRESH_SECRET="min-32-characters-secret-for-refresh-token-min"

# Пароль суперадмина при npm run db:seed (admin@adresov.kz)
ADMIN_SEED_PASSWORD="Admin123!"

# Публичный URL сайта (metadata, sitemap, robots). На Render: https://<имя-сервиса>.onrender.com
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ========== Рекомендуется в продакшене ==========
# На Render после создания Postgres вставьте Internal/External URL с ?sslmode=require при необходимости
# DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"

# ========== Опционально ==========
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Telegram: только заявки «Консультация» (форма на главной).
# 1) @BotFather → /newbot → TELEGRAM_BOT_TOKEN
# 2) Напишите боту в ЛС любое сообщение, затем откройте https://api.telegram.org/bot<TOKEN>/getUpdates → chat.id
#    Для группы: добавьте бота в группу, включите «темы» при необходимости — TELEGRAM_MESSAGE_THREAD_ID
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_MESSAGE_THREAD_ID=

# reCAPTCHA v3 — если RECAPTCHA_SECRET не задан, формы заявок всё равно работают
# RECAPTCHA_SECRET=
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Соцсети в шапке, если не заданы в админке → Настройки
# NEXT_PUBLIC_TELEGRAM_URL=https://t.me/yourchannel
# NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/yourprofile
