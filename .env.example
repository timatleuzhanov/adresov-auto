DATABASE_URL="file:./dev.db"
JWT_ACCESS_SECRET="min-32-characters-secret-for-access-token"
JWT_REFRESH_SECRET="min-32-characters-secret-for-refresh-token"
ADMIN_SEED_PASSWORD="Admin123!"
# Optional SMTP (Nodemailer)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# Google reCAPTCHA v3 (if set, forms verify token)
# RECAPTCHA_SECRET=
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Публичный URL (sitemap, OG)
# NEXT_PUBLIC_SITE_URL=https://your-app.onrender.com

# Соцсети в шапке (если пусто в админке → можно задать здесь)
# NEXT_PUBLIC_TELEGRAM_URL=https://t.me/yourchannel
# NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/yourprofile
